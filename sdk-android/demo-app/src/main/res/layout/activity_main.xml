<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FB">

    <!-- Header: app name + version + live SDK status chip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛍 MyShopApp"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1B2030" />
            <TextView
                android:id="@+id/txt_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#8A94B0" />
        </LinearLayout>

        <TextView
            android:id="@+id/chip_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● בודק…"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#8A94B0"
            android:background="#EDF0F8"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/products_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Chat support card (gated by the "chat" kill switch) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="1dp"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btn_chat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💬 צ'אט תמיכה" />

                <TextView
                    android:id="@+id/txt_chat_disabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textColor="#7A6A2E"
                    android:background="#FBF3DC"
                    android:padding="10dp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Cart / payment bar (gated by the "payments" kill switch) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="16dp">

        <TextView
            android:id="@+id/txt_payments_disabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="13sp"
            android:textColor="#6B7390"
            android:background="#EDF0F8"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone"
            android:text="💳🔒 התשלומים יחזרו בקרוב — אנחנו על זה" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txt_total"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="סה״כ: ₪0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B2030" />

            <Button
                android:id="@+id/btn_pay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💳 לתשלום (0)" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
